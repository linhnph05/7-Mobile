<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (LIGHT) -->
    <style name="Base.Theme.TaskFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/theme_background</item>
        <item name="colorSurface">@color/theme_surface</item>
        <item name="colorOnSurface">@color/theme_text_primary</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:textColorPrimary">@color/theme_text_primary</item>
        <item name="android:textColorSecondary">@color/theme_text_secondary</item>
        <item name="android:textColorHint">@color/theme_text_hint</item>
        
        <!-- Status Bar Colors -->
        <item name="android:statusBarColor">@color/theme_background</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Page Transition Animation -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <!-- Global Activity Animations -->
    <style name="WindowAnimationTransition" parent="@android:style/Animation.Activity">
        <!-- Khi gọi startActivity: Màn hình mới trượt vào từ bên phải, màn hình cũ trượt ra bên trái -->
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <!-- Khi gọi finish (bấm Back): Màn hình cũ trượt vào từ bên trái, màn hình hiện tại trượt ra bên phải -->
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.TaskFlow" parent="Base.Theme.TaskFlow" />

    <!-- FAB hoàn toàn tròn -->
    <style name="ShapeAppearanceOverlay.Fab.Round" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Material3 Full Corner Overlay -->
    <style name="ShapeAppearanceOverlay.Material3.Corner.Full" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- BottomSheet dark theme for project settings panel -->
    <style name="Theme.TaskFlow.BottomSheet" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.TaskFlow.BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.TaskFlow.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.BottomSheet.Rounded</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="ShapeAppearanceOverlay.BottomSheet.Rounded" parent="">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Translucent Overlay Theme for AI Dialog -->
    <style name="Theme.TaskFlow.Translucent" parent="Theme.TaskFlow">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
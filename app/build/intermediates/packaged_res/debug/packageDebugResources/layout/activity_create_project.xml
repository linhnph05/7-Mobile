<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_back"
                    app:tint="@color/theme_text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Create Project"
                    android:textColor="@color/theme_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Project Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Project Name"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etProjectName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_bar"
                android:hint="Enter project name"
                android:textColorHint="@color/theme_text_hint"
                android:textColor="@color/theme_text_primary"
                android:padding="12dp"
                android:inputType="text" />

            <!-- Project Key -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Project Key"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etProjectKey"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_bar"
                android:hint="e.g., PRJ"
                android:textColorHint="@color/theme_text_hint"
                android:textColor="#2945FF"
                android:textStyle="bold"
                android:padding="12dp"
                android:inputType="textCapCharacters"
                android:maxLength="5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Auto-generated from project name (max 5 characters)"
                android:textColor="@color/theme_text_hint"
                android:textSize="12sp" />

            <!-- Project Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Description"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etProjectDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_bar"
                android:hint="Enter project description"
                android:textColorHint="@color/theme_text_hint"
                android:textColor="@color/theme_text_primary"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine" />

            <!-- Visibility -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Visibility"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Public -->
                <LinearLayout
                    android:id="@+id/btnPublic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/bg_option_selected">

                    <ImageView
                        android:id="@+id/icPublic"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_public"
                        app:tint="#2945FF" />

                    <TextView
                        android:id="@+id/tvPublic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Public"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Anyone can view"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Private -->
                <LinearLayout
                    android:id="@+id/btnPrivate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/bg_option_unselected">

                    <ImageView
                        android:id="@+id/icPrivate"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/theme_text_hint" />

                    <TextView
                        android:id="@+id/tvPrivate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Private"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Only members"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Template -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Template"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Kanban -->
                <LinearLayout
                    android:id="@+id/btnKanban"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_option_selected">

                    <ImageView
                        android:id="@+id/icKanban"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_view_column"
                        app:tint="#2945FF" />

                    <TextView
                        android:id="@+id/tvKanban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Kanban"
                        android:textColor="@color/theme_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Scrum -->
                <LinearLayout
                    android:id="@+id/btnScrum"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_option_unselected">

                    <ImageView
                        android:id="@+id/icScrum"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_sprint"
                        app:tint="@color/theme_text_secondary" />

                    <TextView
                        android:id="@+id/tvScrum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Scrum"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Table -->
                <LinearLayout
                    android:id="@+id/btnTable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_option_unselected">

                    <ImageView
                        android:id="@+id/icTable"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_table"
                        app:tint="@color/theme_text_secondary" />

                    <TextView
                        android:id="@+id/tvTable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Table"
                        android:textColor="@color/theme_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Project Color -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Project Color"
                android:textColor="@color/theme_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/colorPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#6D88FF"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/primary">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#FF9D7E"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#7DD0B3"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#C893EF"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#64DADB"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="@color/theme_text_primary"
                    android:backgroundTint="@color/theme_surface_variant"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnCreate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Create Project"
                    android:textColor="@color/white"
                    android:backgroundTint="#2945FF"
                    android:textAllCaps="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>


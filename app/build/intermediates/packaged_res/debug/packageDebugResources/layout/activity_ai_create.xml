<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/bgOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:clickable="true"
        android:focusableInTouchMode="true"
        android:paddingTop="8dp">

        <EditText
            android:id="@+id/etPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@null"
            android:hint="Thêm tác vụ (Ví dụ: Nhắn tin cho Đức lúc 3h chiều mai...)"
            android:inputType="textMultiLine"
            android:minHeight="140dp"
            android:gravity="top|start"
            android:textColor="@color/theme_text_primary"
            android:textColorHint="@color/theme_text_hint"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomDivider" />

        <View
            android:id="@+id/bottomDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/theme_surface_variant"
            app:layout_constraintBottom_toTopOf="@id/bottomToolbar" />

        <!-- THỰC HIỆN TÁCH 2 HÀNG: HÀNG THẺ VÀ HÀNG NÚT GỬI DI -->
        <LinearLayout
            android:id="@+id/bottomToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Title Field Explicit (Khôi phục) -->
            <EditText
                android:id="@+id/etParsedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Chưa có tên tác vụ..."
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/theme_text_primary"
                android:textColorHint="@color/theme_text_hint"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp"> <!-- Chừa lề dưới để không cấn dải nút gửi -->

                    <!-- 1. Start Date Chip -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardStartDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/theme_surface_variant"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/ivParsedStartDate"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_calendar_today"
                                app:tint="@color/theme_text_hint" />
                            <TextView
                                android:id="@+id/tvParsedStartDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bắt đầu"
                                android:textColor="@color/theme_text_hint"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 2. Due Date Chip -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDueDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/theme_surface_variant"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/ivParsedDueDate"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_calendar_today"
                                app:tint="@color/theme_text_hint" />
                            <TextView
                                android:id="@+id/tvParsedDueDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hết hạn"
                                android:textColor="@color/theme_text_hint"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 3. Priority Chip (Cờ Emoji) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPriority"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/theme_surface_variant"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/tvParsedPriority"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏳️"
                                android:textColor="@color/theme_text_hint"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 4. Assignee Chip -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardAssignee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/theme_surface_variant"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/ivParsedAssignee"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_account_box"
                                app:tint="@color/theme_text_hint" />
                            <TextView
                                android:id="@+id/tvParsedAssignee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phân công"
                                android:textColor="@color/theme_text_hint"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- 5. Tag Chip -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/theme_surface_variant"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/ivParsedTag"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="6dp"
                                android:src="@android:drawable/ic_menu_edit"
                                app:tint="@color/theme_text_hint" />
                            <TextView
                                android:id="@+id/tvParsedTag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nhãn"
                                android:textColor="@color/theme_text_hint"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- NẮM NÚT GỬI Ở HÀNG DƯỚI ĐỘC LẬP -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">
                    <ImageButton
                        android:id="@+id/btnSaveTask"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/white" />
                </androidx.cardview.widget.CardView>

            </RelativeLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
